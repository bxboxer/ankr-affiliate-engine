# ── Database (Neon Postgres) ────────────────────────────────────────
# Connection string from Neon dashboard — https://console.neon.tech
POSTGRES_URL=

# ── Admin Auth ──────────────────────────────────────────────────────
# Simple password gate for admin access (set a strong password)
ADMIN_PASSWORD=H5ugX!@1*2K4@1Xn

# ── GitHub API ──────────────────────────────────────────────────────
# Personal access token with repo scope — https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_OWNER=bxboxer

# ── Vercel API ──────────────────────────────────────────────────────
# Account token — https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# ── Anthropic (Claude AI) ──────────────────────────────────────────
# API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Google Ads API (Keyword Planner) ─────────────────────────────
# Developer token from Google Ads API Center
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_MCC_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# ── Google Search Console (OAuth) ────────────────────────────────
# Reuses Google Ads OAuth client; separate refresh token for GSC scope
GOOGLE_GSC_CLIENT_ID=
GOOGLE_GSC_CLIENT_SECRET=
GOOGLE_GSC_REFRESH_TOKEN=

# ── Legacy GSC (service account) ─────────────────────────────────
# Service account JSON (base64 encoded) — optional fallback
GSC_SERVICE_ACCOUNT_B64=

# ── Template Repo ──────────────────────────────────────────────────
TEMPLATE_REPO=ankr-affiliate-template
